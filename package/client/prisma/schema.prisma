generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  email         String          @unique
  name          String?
  password      String
  projects      Project[]       @relation("OwnedProjects")
  createdAt     DateTime        @default(now())
  memberships   ProjectMember[] @relation("UserProjectMemberships")
}

model Project {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  ownerId   String          @db.ObjectId
  owner     User            @relation("OwnedProjects", fields: [ownerId], references: [id])
  files     File[]
  members   ProjectMember[]
  createdAt DateTime        @default(now())
}

model File {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  content   String
  projectId String        @db.ObjectId
  project   Project       @relation(fields: [projectId], references: [id])
  parentId  String?       @db.ObjectId
  type      String // file | folder
  updatedAt DateTime      @updatedAt
  versions  FileVersion[]
}

model ProjectMember {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  projectId String @db.ObjectId
  role      String // owner | editor | viewer

  user    User    @relation("UserProjectMemberships", fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model FileVersion {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  fileId                String   @db.ObjectId
  projectId             String   @db.ObjectId
  file                  File     @relation(fields: [fileId], references: [id])
  content               String
  createdById           String?  @db.ObjectId
  restoredFromVersionId String?  @db.ObjectId
  createdAt             DateTime @default(now())
}
